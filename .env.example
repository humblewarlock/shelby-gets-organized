# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — used server-side only (server.js), never exposed to the browser.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the Express API server port (default: 3001)
# API_PORT=3001

# Supabase — used server-side only, never exposed to the browser.
# 1. Create a free project at https://supabase.com
# 2. Run the SQL in supabase/schema.sql in the Supabase SQL editor
# 3. Copy URL from:  Project Settings → API → Project URL
# 4. Copy key from:  Project Settings → API → anon / public  (or service_role for stricter access)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_key_here
